# --- Spring Boot backend configuration (all values have sensible defaults) ---

# Database (either set SPRING_DATASOURCE_URL, or the discrete DB_* / Railway MYSQL* vars)
# SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/checkin_checkout
DB_HOST=localhost
DB_PORT=3306
DB_NAME=checkin_checkout
DB_USER=root
DB_PASSWORD=rootpassword

# Security
JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_bytes
SYSTEM_ADMIN_EMAIL=zdravko.h.anev@gmail.com
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
FRONTEND_BASE_URL=http://localhost:8080

# Account-security policy
PASSWORD_RESET_TOKEN_MINUTES=30
SECURITY_MAX_FAILED_LOGINS=5
SECURITY_LOCKOUT_MINUTES=15
SECURITY_PASSWORD_HISTORY_DEPTH=5
SECURITY_REQUIRE_EMAIL_VERIFICATION=false
SECURITY_EMAIL_VERIFICATION_HOURS=48

# Mail (leave MAIL_SMTP_HOST empty to log emails only)
MAIL_FROM=school.inventory.bot@gmail.com
MAIL_FROM_NAME=UKTC Pansion
MAIL_SMTP_HOST=
MAIL_SMTP_PORT=587
MAIL_SMTP_USERNAME=
MAIL_SMTP_PASSWORD=
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true
MAIL_FORCE_LOG_ONLY=false

# Optional
APP_TIMEZONE=Europe/Sofia
# PORT=8080
