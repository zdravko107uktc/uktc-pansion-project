APP_ENV=production
JWT_SECRET=change_this_to_a_secure_random_secret_in_production
SYSTEM_ADMIN_EMAIL=zdravko.h.anev@gmail.com

# Frontend origin(s) allowed to call the API from Vercel.
# Separate multiple values with commas.
CORS_ALLOWED_ORIGINS=https://your-project.vercel.app

# Railway MySQL plugin can provide MYSQLHOST, MYSQLPORT, MYSQLDATABASE, MYSQLUSER, MYSQLPASSWORD automatically.
# If you prefer a single URL, set DATABASE_URL instead.
# DATABASE_URL=mysql://user:password@host:3306/database

MAIL_FROM=school.inventory.bot@gmail.com
MAIL_FROM_NAME=school-inventory-management-system
MAIL_SMTP_HOST=smtp.gmail.com
MAIL_SMTP_PORT=587
MAIL_SMTP_ENCRYPTION=tls
MAIL_SMTP_USERNAME=your_account@gmail.com
MAIL_SMTP_PASSWORD=your_app_password
MAIL_SMTP_TIMEOUT=10
MAIL_EHLO_DOMAIN=localhost

FRONTEND_BASE_URL=https://your-project.vercel.app
PASSWORD_RESET_TOKEN_MINUTES=30
MAIL_FORCE_LOG_ONLY=0
